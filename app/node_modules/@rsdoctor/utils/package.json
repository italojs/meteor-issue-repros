{
  "name": "@rsdoctor/utils",
  "version": "1.6.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rsdoctor",
    "directory": "packages/utils"
  },
  "type": "module",
  "license": "MIT",
  "exports": {
    "./common": {
      "import": {
        "types": "./dist/common/index.d.ts",
        "default": "./dist/common.js"
      },
      "require": {
        "types": "./dist/common/index.d.cts",
        "default": "./dist/common.cjs"
      }
    },
    "./build": {
      "import": {
        "types": "./dist/build/index.d.ts",
        "default": "./dist/build.js"
      },
      "require": {
        "types": "./dist/build/index.d.cts",
        "default": "./dist/build.cjs"
      }
    },
    "./error": {
      "import": {
        "types": "./dist/error/index.d.ts",
        "default": "./dist/error.js"
      },
      "require": {
        "types": "./dist/error/index.d.cts",
        "default": "./dist/error.cjs"
      }
    },
    "./ruleUtils": {
      "import": {
        "types": "./dist/rule-utils/index.d.ts",
        "default": "./dist/ruleUtils.js"
      },
      "require": {
        "types": "./dist/rule-utils/index.d.cts",
        "default": "./dist/ruleUtils.cjs"
      }
    },
    "./logger": {
      "import": {
        "types": "./dist/logger.d.ts",
        "default": "./dist/logger.js"
      },
      "require": {
        "types": "./dist/logger.d.cts",
        "default": "./dist/logger.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "common": [
        "./dist/common/index.d.ts"
      ],
      "build": [
        "./dist/build/index.d.ts"
      ],
      "error": [
        "./dist/error/index.d.ts"
      ],
      "ruleUtils": [
        "./dist/rule-utils/index.d.ts"
      ],
      "logger": [
        "./dist/logger.d.ts"
      ]
    }
  },
  "main": "dist/build.cjs",
  "module": "dist/build.js",
  "types": "dist/build/index.d.ts",
  "files": [
    "dist",
    "compiled"
  ],
  "dependencies": {
    "@babel/code-frame": "7.26.2",
    "@types/estree": "1.0.5",
    "acorn": "^8.10.0",
    "acorn-import-attributes": "^1.9.5",
    "acorn-walk": "8.3.5",
    "deep-eql": "4.1.4",
    "envinfo": "7.21.0",
    "fs-extra": "^11.1.1",
    "get-port": "5.1.1",
    "json-stream-stringify": "3.0.1",
    "lines-and-columns": "2.0.4",
    "picocolors": "^1.1.1",
    "rslog": "^2.1.2",
    "strip-ansi": "^7.2.0",
    "@rsdoctor/types": "1.6.0"
  },
  "devDependencies": {
    "@types/babel__code-frame": "7.27.0",
    "@types/connect": "3.4.38",
    "@types/deep-eql": "4.0.2",
    "@types/envinfo": "7.8.4",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.12.3",
    "prebundle": "1.6.5",
    "filesize": "^11.0.17",
    "connect": "3.7.0",
    "tslib": "2.8.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "npm run prebundle && rslib build",
    "dev": "npm run start",
    "start": "rslib build -w",
    "test": "rstest run",
    "prebundle": "prebundle"
  }
}