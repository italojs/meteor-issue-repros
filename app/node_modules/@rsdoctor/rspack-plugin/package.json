{
  "name": "@rsdoctor/rspack-plugin",
  "version": "1.6.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rsdoctor",
    "directory": "packages/rspack-plugin"
  },
  "license": "MIT",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "type": "module",
  "dependencies": {
    "@rsdoctor/graph": "1.6.0",
    "@rsdoctor/sdk": "1.6.0",
    "@rsdoctor/types": "1.6.0",
    "@rsdoctor/core": "1.6.0",
    "@rsdoctor/utils": "1.6.0"
  },
  "devDependencies": {
    "@rspack/core": "^2.0.5",
    "@types/node": "^24.12.3",
    "@types/tapable": "2.3.0",
    "tslib": "2.8.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@rspack/core": "*"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "npm run start",
    "start": "rslib build -w",
    "build": "rslib build",
    "test": "rstest run"
  }
}