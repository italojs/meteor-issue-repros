{
  "isopack-2": {
    "name": "hot-module-replacement",
    "summary": "Update code in development without reloading the page",
    "version": "0.6.0",
    "isTest": false,
    "builds": [
      {
        "kind": "main",
        "arch": "os",
        "path": "os.json"
      },
      {
        "kind": "main",
        "arch": "web.browser",
        "path": "web.browser.json"
      }
    ],
    "plugins": [],
    "debugOnly": true
  }
}