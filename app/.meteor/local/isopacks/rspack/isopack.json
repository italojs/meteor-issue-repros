{
  "isopack-2": {
    "name": "rspack",
    "summary": "Integrate rspack into the Meteor lifecycle to run the bundler independently",
    "version": "1.1.0",
    "isTest": false,
    "builds": [
      {
        "kind": "main",
        "arch": "os",
        "path": "os.json"
      },
      {
        "kind": "main",
        "arch": "web.browser",
        "path": "web.browser.json"
      }
    ],
    "plugins": [
      {
        "name": "rspack",
        "arch": "os",
        "path": "plugin.rspack.os/program.json"
      }
    ]
  }
}