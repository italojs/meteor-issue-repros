{
  "isopack-2": {
    "name": "templating-compiler",
    "summary": "Compile templates in .html files",
    "version": "2.0.1",
    "isTest": false,
    "builds": [
      {
        "kind": "main",
        "arch": "os",
        "path": "os.json"
      },
      {
        "kind": "main",
        "arch": "web.browser",
        "path": "web.browser.json"
      }
    ],
    "plugins": [
      {
        "name": "compileTemplatesBatch",
        "arch": "os",
        "path": "plugin.compileTemplatesBatch.os/program.json"
      }
    ]
  }
}