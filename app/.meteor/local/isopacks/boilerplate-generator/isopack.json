{
  "isopack-2": {
    "name": "boilerplate-generator",
    "summary": "Generates the boilerplate html from program's manifest",
    "version": "2.1.0",
    "isTest": false,
    "builds": [
      {
        "kind": "main",
        "arch": "os",
        "path": "os.json"
      },
      {
        "kind": "main",
        "arch": "web.browser",
        "path": "web.browser.json"
      }
    ],
    "plugins": []
  }
}