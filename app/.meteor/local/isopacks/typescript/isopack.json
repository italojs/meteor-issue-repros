{
  "isopack-2": {
    "name": "typescript",
    "summary": "Compiler plugin that compiles TypeScript and ECMAScript in .ts and .tsx files",
    "version": "5.10.1",
    "isTest": false,
    "builds": [
      {
        "kind": "main",
        "arch": "os",
        "path": "os.json"
      },
      {
        "kind": "main",
        "arch": "web.browser",
        "path": "web.browser.json"
      }
    ],
    "plugins": [
      {
        "name": "compile-typescript",
        "arch": "os",
        "path": "plugin.compile-typescript.os/program.json"
      }
    ],
    "devOnly": true
  }
}