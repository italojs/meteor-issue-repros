CK_NATIVE","shuffleString","require","createProxyMiddleware","target","RSPACK_DEVSERVER_PORT","WebApp","connectHandlers","use","ws","logLevel","changeOrigin","rawConnectHandlers","req","res","next","url","startsWith","hotUpdate","match","RSPACK_HOT_UPDATE_REGEX","writeHead","Location","end","bundlesMatch","assetsMatch","enableClientReloadOnServerStart","startup","originalCalc","calculateClientHashReplaceable","hasShuffled","cachedHash","prevRealHash","args","arch","realHash","apply","registerRspackStaticAsset","pathname","filePath","WebAppInternals","staticFilesByArch","Object","create","staticFiles","cacheable","type","endsWith","undefined","filename","split","pop","hash","absolutePath","originalStaticFilesMiddleware","staticFilesMiddleware","parseUrl","chunksMatch","cwd","architectures","categorizeRequest","context","path","join","forEach","archName","e","console","error","message","Plugin","DEFAULT_RSPACK_VERSION","DEFAULT_METEOR_RSPACK_VERSION","DEFAULT_METEOR_RSPACK_REACT_HMR_VERSION","DEFAULT_METEOR_RSPACK_REACT_REFRESH_VERSION","DEFAULT_METEOR_RSPACK_SWC_LOADER_VERSION","DEFAULT_METEOR_RSPACK_SWC_HELPERS_VERSION","DEFAULT_RSDOCTOR_RSPACK_PLUGIN_VERSION","GLOBAL_STATE_KEYS","CLIENT_PROCESS","SERVER_PROCESS","RSPACK_INSTALLATION_CHECKED","RSPACK_REACT_INSTALLATION_CHECKED","RSPACK_DOCTOR_INSTALLATION_CHECKED","REACT_CHECKED","TYPESCRIPT_CHECKED","ANGULAR_CHECKED","INITIAL_ENTRYPONTS","CLIENT_FIRST_COMPILE","SERVER_FIRST_COMPILE","BUILD_CONTEXT_FILES_CLEANED","meteorConfig","getMeteorConfig","meteorLocalDirName","METEOR_LOCAL_DIR","basename","replace","RSPACK_BUILD_CONTEXT","buildContext","assetsContext","chunksContext","RSPACK_DOCTOR_CONTEXT","FILE_ROLE","build","entry","run","output"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;IA+BEA;AA/BqC;AACiB;AAChC;AACgB;AAKf;AAEzB,uDAAuD;AACvD,MAAMC,sBAAsBC,QAAQC,GAAG,CAACC,qBAAqB,IAAIA;AACjE,MAAMC,sBAAsBH,QAAQC,GAAG,CAACG,qBAAqB,IAAIA;AAEjE;;;CAGC,GACD,MAAMC,sBAAsB,IAAIC,OAC9B,CAAC,GAAG,EAAEP,oBAAoB,OAA